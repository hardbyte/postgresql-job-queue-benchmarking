__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build artefacts
target/
node_modules/
_build/
deps/
.elixir_ls/

# Bench outputs (ignore generated runs; checked-in snapshots live under
# results/<date>/ and are added explicitly). Raw CSVs are too big for
# git; keep them locally and regenerate on demand.
results/custom-*/
results/*-combined/
results/chaos_*/
results/**/raw.csv
*.log

# Per-language lock files in adapter dirs that aren't part of the
# tracked contract (Python uv, Elixir mix). Rust binaries do track
# Cargo.lock; Node tracks package-lock.json — those stay.
*-bench/uv.lock
*-bench/mix.lock

# Local env
.env
.env.local

# OS noise
.DS_Store
Thumbs.db
